# Copy this file to .env and fill in your values

# Gmail address you want to send emails FROM
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password-here

# Email address where YOU receive booking notifications
ADMIN_EMAIL=your-personal-email@gmail.com

# Admin dashboard password
ADMIN_PASSWORD=VillaVelha2026!

# Secret token for admin API (make this a long random string)
ADMIN_TOKEN=change-this-to-a-long-random-secret-string

# Port (default 3000)
PORT=3000
